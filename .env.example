# SDOH Bridge Agent — Environment Configuration
# Copy this to .env and fill in your values

# ── Google AI Studio ──────────────────────────────────────────────────────────
# Required: Your Google AI Studio API key
# Get it at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyB3A5q0oRNdB3lNyckABfLs8IBdF0GHI5E
GOOGLE_GENAI_API_KEY=AIzaSyB3A5q0oRNdB3lNyckABfLs8IBdF0GHI5E

# ── Agent URLs ────────────────────────────────────────────────────────────────
# These are used for A2A agent-to-agent communication
SDOH_BRIDGE_AGENT_URL=http://localhost:3001
RESOURCE_AGENT_URL=http://localhost:3002
OUTREACH_AGENT_URL=http://localhost:3003
ORCHESTRATOR_URL=http://localhost:3000

# ── FHIR Server ───────────────────────────────────────────────────────────────
# Synthea mock FHIR server (run with: npx tsx synthea/generate.ts)
FHIR_SERVER_URL=http://localhost:8080
FHIR_SERVER_TOKEN=demo-token

# ── Prompt Opinion ───────────────────────────────────────────────────────────
# FHIR extension URI (Prompt Opinion injects credentials via this)
FHIR_EXTENSION_URI=http://localhost:5139/schemas/a2a/v1/fhir-context

# ── API Keys ──────────────────────────────────────────────────────────────────
# Primary API key for agent authentication
API_KEY_PRIMARY=sdoh-bridge-secret-key-2026
API_KEY_SECONDARY=another-valid-key

# ── Ports ─────────────────────────────────────────────────────────────────────
PORT=3001
