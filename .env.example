# SDOH Bridge Agent — Environment Configuration
# Copy to .env and fill in your values

# ── Google AI Studio ──────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyB3A5q0oRNdB3lNyckABfLs8IBdF0GHI5E

# Forward to TypeScript ADK convention
GOOGLE_GENAI_API_KEY=AIzaSyB3A5q0oRNdB3lNyckABfLs8IBdF0GHI5E

# ── Port Configuration ───────────────────────────────────────────────────────
PORT=3000

# Agent URLs (for A2A agent discovery)
SDOH_BRIDGE_AGENT_URL=http://localhost:3001
RESOURCE_AGENT_URL=http://localhost:3002
REFERRAL_AGENT_URL=http://localhost:3003
OUTREACH_AGENT_URL=http://localhost:3004

# ── FHIR Server ───────────────────────────────────────────────────────────────
# For demo: set FHIR_MOCK=true to use local Synthea JSON files
# For real: point to your FHIR R4 server (Epic, Cerner, HAPI, etc.)
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_MOCK=true

# Prompt Opinion FHIR Extension (for extracting FHIR context from A2A messages)
FHIR_EXTENSION_URI=http://localhost:5139/schemas/a2a/v1/fhir-context

# ── API Keys ─────────────────────────────────────────────────────────────────
# Primary API key for agent authentication
API_KEY_PRIMARY=sdoh-bridge-secret-key-2026

# ── Community Resource API (Production) ─────────────────────────────────────
# Aunt Bertha / 211 API keys (paid service — mock for demo)
AUNT_BERTHA_API_KEY=your_aunt_bertha_key_here
211_API_KEY=your_211_key_here

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
