# ── Required ──────────────────────────────────────────────────────────────────

# Google AI Studio API key — get a free key at https://aistudio.google.com/app/apikey
#
# The TypeScript ADK (@google/adk) reads this from GOOGLE_GENAI_API_KEY or
# GEMINI_API_KEY.  appFactory.ts automatically aliases GOOGLE_API_KEY to
# GOOGLE_GENAI_API_KEY so that both the Python and TypeScript repos can use the
# same .env file without any changes.
#
# Option A — use GOOGLE_API_KEY (same as the Python project):
GOOGLE_API_KEY=your-google-api-key-here
#
# Option B — use the name the TypeScript ADK natively expects:
# GOOGLE_GENAI_API_KEY=your-google-api-key-here

# Set to FALSE to use AI Studio (free) instead of Vertex AI (billed).
GOOGLE_GENAI_USE_VERTEXAI=FALSE


# ── Optional — public URLs for agent cards ────────────────────────────────────
# These populate the "url" field in each agent card — use defaults for local dev
# and set them to your Cloud Run URLs after deploying.

HEALTHCARE_AGENT_URL=http://localhost:8001
GENERAL_AGENT_URL=http://localhost:8002
ORCHESTRATOR_URL=http://localhost:8003


# ── Optional — API keys for authenticated agents ──────────────────────────────
# Loaded by shared/middleware.ts. Agents fall back to hardcoded defaults if
# these are not set (fine for local dev, change before production).

API_KEY_PRIMARY=my-secret-key-123
API_KEY_SECONDARY=another-valid-key


# ── Optional — FHIR context ───────────────────────────────────────────────────
# The extension URI must match the value registered in your Prompt Opinion workspace.
# Only needed for the healthcare_agent and orchestrator.

FHIR_EXTENSION_URI=https://your-workspace.promptopinion.ai/schemas/a2a/v1/fhir-context


# ── Optional — logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
